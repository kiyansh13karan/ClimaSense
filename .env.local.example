# ============================================================
# AtmosIQ — Environment Variables Template
# Copy this file to .env.local and fill in your keys
# ============================================================

# OpenWeather API (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Tomorrow.io API (https://app.tomorrow.io/development/keys)
TOMORROW_API_KEY=your_tomorrow_io_api_key_here

# Groq API — Llama 3.3 70B (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Set to "true" to use mock data instead of live APIs
NEXT_PUBLIC_DEMO_MODE=false
